@import "tailwindcss";

:root {
  --bg-primary: #faf9fc;
  --bg-secondary: #f4f3f8;
  --bg-tertiary: #eeeef4;
  --accent-purple: #7c3aed;
  --accent-cyan: #0891b2;
  --accent-gradient: linear-gradient(135deg, #7c3aed, #0891b2);
  --text-primary: #111827;
  --text-secondary: #4b5563;
  --text-tertiary: #9ca3af;
  --border-subtle: rgba(124, 58, 237, 0.12);
  --border-glow: rgba(124, 58, 237, 0.25);
  --card-bg: #ffffff;
  --card-border: rgba(0, 0, 0, 0.06);
  --card-shadow: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.03);
  --card-shadow-hover: 0 10px 30px rgba(124,58,237,0.08);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 24px;
  --transition-smooth: 300ms cubic-bezier(0.4, 0, 0.2, 1);
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  background-color: var(--bg-primary);
  color: var(--text-secondary);
  font-family: "Inter", sans-serif;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

#particle-canvas {
  position: fixed; top: 0; left: 0;
  width: 100vw; height: 100vh;
  z-index: 0; pointer-events: none;
}

::selection { background: rgba(124, 58, 237, 0.15); color: var(--text-primary); }

.section-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px;
}
@media (max-width: 768px) {
  .section-container { padding: 0 20px; }
}

/* 鏉垮潡涔嬮棿鐨勫垎闅?*/
.section-divider {
  position: relative;
}
.section-divider::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 600px;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--accent-purple), var(--accent-cyan), var(--accent-purple), transparent);
  opacity: 0.5;
}

/* 鏉垮潡涔嬮棿鐨勯棿璺?*/
.section-spacing {
  padding: 100px 0;
}
@media (max-width: 768px) {
  .section-spacing {
    padding: 60px 0;
  }
}

/* 浜ゆ浛鏉垮潡鑳屾櫙鑹?- 娴呰壊鑳屾櫙 */
.section-alt-bg {
  background-color: var(--bg-secondary);
}

/* 鏉垮潡鍐呭灞呬腑瀹瑰櫒 */
.section-content {
  max-width: 800px;
  margin: 0 auto;
}

.glass-card {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--card-shadow);
  transition: all var(--transition-smooth);
}
.glass-card:hover {
  border-color: var(--border-glow);
  box-shadow: var(--card-shadow-hover);
}

.glass-card-header {
  padding-bottom: 16px;
  margin-bottom: 20px;
  border-bottom: 1px solid var(--card-border);
}

.gradient-text {
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.glow-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 28px;
  border-radius: var(--radius-sm);
  font-weight: 600;
  font-size: 14px;
  cursor: pointer;
  transition: all var(--transition-smooth);
  text-decoration: none;
  border: none;
}
.glow-btn-primary {
  background: var(--accent-gradient);
  color: white;
  box-shadow: 0 4px 14px rgba(124, 58, 237, 0.25);
}
.glow-btn-primary:hover {
  box-shadow: 0 6px 24px rgba(124, 58, 237, 0.35);
  transform: translateY(-1px);
}
.glow-btn-secondary {
  background: transparent;
  color: var(--text-primary);
  border: 1px solid var(--border-subtle);
}
.glow-btn-secondary:hover {
  border-color: var(--accent-purple);
  background: rgba(124, 58, 237, 0.05);
  transform: translateY(-1px);
}

.nav-blur {
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  background: rgba(250, 249, 252, 0.85);
  border-bottom: 1px solid rgba(0,0,0,0.05);
}

.progress-bar {
  height: 10px;
  border-radius: 999px;
  background: var(--bg-tertiary);
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  border-radius: 999px;
  background: var(--accent-gradient);
  transition: width 0.8s ease;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(6px); }
}
.bounce-arrow { animation: bounce 2s ease-in-out infinite; }

